# Vorlage — kopiere diese Datei zu ".env" und trage dort deine echten Werte ein.
# ".env" wird NICHT ins Git-Repo eingecheckt (siehe .gitignore).

# CSFloat API-Key (Account-Einstellungen auf csfloat.com)
CSFLOAT_API_KEY=dein_csfloat_key_hier

# Hinweis: Die Deal-/Alarm-Schwellen (Prozent) liegen in data/settings.json
# und sind im Dashboard editierbar - nicht mehr hier.

# Telegram-Alarm (Bot ueber @BotFather, Chat-/Gruppen-ID). Leer lassen = kein Alarm.
TELEGRAM_BOT_TOKEN=dein_bot_token_hier
TELEGRAM_CHAT_ID=deine_chat_id_hier

# Steam-Handelshistorie (Tauschgeschaefte). Braucht den eingeloggten Session-Cookie,
# weil Steams Web-API die Item-Inhalte von Trades NICHT herausgibt (nur Metadaten).
# steamLoginSecure-Cookie: eingeloggt auf steamcommunity.com -> F12 -> Application ->
# Cookies -> steamcommunity.com -> Wert von "steamLoginSecure" kopieren.
# Leer lassen = Trade-Feature aus. Sicherheit + Zuruecksetzen: siehe README.
STEAM_LOGIN_SECURE=dein_steamloginsecure_cookie_hier

# (Optional, aktuell NICHT genutzt) Steam-Web-API-Key. Reicht fuer die Trade-Items
# nicht aus - Valve liefert darueber keine Item-Inhalte. Nur der Cookie oben zaehlt.
STEAM_API_KEY=dein_steam_web_api_key_hier

# Dashboard-Login (Basic-Auth). Beide setzen = Login-Pflicht; leer lassen = offen
# (dann nur im vertrauenswuerdigen Netz betreiben, z.B. Heimnetz/Tailscale).
DASHBOARD_USER=
DASHBOARD_PASSWORD=

# Wie oft (in Sekunden) das Skript im Dauerbetrieb die Watchlist neu abfragt
POLL_INTERVAL_SECONDS=300

# Inventarbewertung. Die manuelle Liste (Lagereinheiten-Inhalte, nicht im CSFloat-
# Inventar) liegt lokal in data/manual_items.json ({"market_hash_name": menge}) und
# ist frei editierbar - keine Google-Anbindung mehr noetig.
INVENTORY_INTERVAL_SECONDS=3600
STEAM_REFRESH_PER_RUN=10
